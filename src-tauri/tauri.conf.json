{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aitrans",
  "mainBinaryName": "aitrans",
  "version": "0.1.0",
  "identifier": "com.example.aitrans",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "AI 实时翻译 - 设置",
        "width": 800,
        "height": 700,
        "resizable": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "",
        "url": "/overlay",
        "width": 600,
        "height": 200,
        "minWidth": 200,
        "minHeight": 60,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "visible": false,
        "resizable": true,
        "skipTaskbar": true,
        "x": 100,
        "y": 50
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "14.2"
    }
  }
}
